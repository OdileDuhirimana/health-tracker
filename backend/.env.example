NODE_ENV=development
PORT=3001

# Supabase (recommended single connection string)
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?sslmode=require

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=healthtrackdb
DB_SSL=false
# Defaults to `true` (verify the DB server's TLS certificate) whenever
# NODE_ENV is not "development". Only set this to `false` if you are
# intentionally connecting to a database presenting a self-signed or
# otherwise untrusted certificate — doing so disables MITM protection on the
# database connection and logs a startup warning.
# DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=3

# Redis-backed rate limiting. Required for correct multi-instance rate
# limiting in production (see RedisThrottlerStorage) — without it, each
# running instance enforces its own independent limit. Safe to leave unset
# in local development/CI, where it falls back to per-instance in-memory
# limiting.
# REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# For production, set to false unless explicitly required.
ENABLE_SWAGGER=true

# Optional public app settings for startup logs.
APP_PROTOCOL=http
APP_HOST=localhost
HOST=0.0.0.0

# Error tracking (optional). Leave unset to disable — the app runs
# identically either way, it just has no error-tracking integration.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
